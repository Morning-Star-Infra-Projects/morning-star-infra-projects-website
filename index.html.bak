    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
  </a>

  <!-- QUOTE MODAL -->
  <div id="quote-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-label="Request a Quote">
    <div class="modal-box">
      <button class="modal-close" id="modal-close" aria-label="Close"></button>
      <h2 class="modal-title">Get a Free Quote</h2>
      <p class="modal-sub">Our engineering team will respond within 24 hours.</p>
      <form id="quote-form" class="quote-form" novalidate>
        <div class="form-row">
          <input type="text" id="qf-name" placeholder="Your Full Name" required/>
          <input type="tel" id="qf-phone" placeholder="Phone / WhatsApp" required/>
        </div>
        <input type="email" id="qf-email" placeholder="Email Address"/>
        <select id="qf-service">
          <option value="">Select Service Required</option>
          <option>Home Construction</option>
          <option>Interior Fitouts</option>
          <option>Structural Repair &amp; Retrofitting</option>
          <option>Commercial / Industrial Construction</option>
          <option>Other / Multiple Services</option>
        </select>
        <textarea id="qf-msg" rows="3" placeholder="Brief description of your project (location, size, timeline)"></textarea>
        <button type="submit" class="btn-primary btn-full">Submit Request →</button>
      </form>
    </div>
  </div>

  <script>
  (function(){
    var iframe = document.getElementById('site-map-iframe');
    if(!iframe) return;
    var loadMap = function(){
      var src = iframe.getAttribute('data-src');
      if(src && (iframe.src === '' || iframe.src === 'about:blank')) iframe.src = src;
    };
    // Eager, short delayed load so the map is available before users scroll to it
    if(document.readyState === 'complete' || document.readyState === 'interactive'){
      setTimeout(loadMap, 500);
    } else {
      window.addEventListener('DOMContentLoaded', function(){ setTimeout(loadMap, 500); }, {once:true});
    }
    // Safety: ensure it loads after 3s if anything blocks
    setTimeout(function(){ if(iframe.src==='about:blank') loadMap(); }, 3000);
  })();
  </script>
  <script src="./assets/js/main.min.js" defer></script>
  <script src="./assets/js/navigation.js" defer></script>
  <script src="./assets/js/animations.js" defer></script>
  <script src="https://unpkg.com/lucide@latest" defer></script>
</body>
</html>
