<!-- PRICING -->
<div class="section" style="background:var(--white)">
 <div class="container">
 <div style="text-align:center;margin-bottom:48px">
 <span class="section-tag" style="font-size:14px;font-weight:800;letter-spacing:.22em">TRANSPARENT PRICING</span>
 <h2 class="section-title" style="font-size:clamp(2rem,4.5vw,3.4rem);font-weight:900">Choose Your Package</h2>
 <div class="divider" style="margin:12px auto 16px"></div>
 <p class="section-sub" style="margin:0 auto">All packages include engineering-grade materials — ARS/Tata Steel, Ramco/Dalmia Cement, Wire-cut/AAC bricks.</p>
 </div>
 <div id="pricing-announce" role="status" aria-live="polite" aria-atomic="true" style="position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden"></div>
 <section class="construction-packages">

  <!-- BASIC -->
  <div class="package-card">

    <div class="package-top">
      <h3>BASIC PACKAGE</h3>

      <div class="price-area">
        <span class="rupee">₹</span>
        <span class="price">1999</span>
        <span class="unit">per sqft</span>
      </div>
    </div>

    <div class="accordion">
      <div class="accordion-item">
        <button class="accordion-btn">Design <span>+</span></button>
        <div class="content">
          <ul>
            <li>SCHEME DRAWING : ALL FLOORS (2D)</li>
            <li>ELEVATION DESIGN : (3D)</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Project Management <span>+</span></button>
        <div class="content">
          <ul>
            <li>Site Engineer : One Visit Per Day</li>
            <li>Project Manager : Visit site Once in a Week</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Structure <span>+</span></button>
        <div class="content">
          <ul>
            <li>Basement Height : Upto 2 feet</li>
            <li>Steel : Any ISI Brand</li>
            <li>Fly Ash Brick : Partition & walls (9" exterior / 4.5" inner)</li>
            <li>Cement : for concrete - Coromandel; for other works - Priya</li>
            <li>M Sand : Brick work & All Masonry Works</li>
            <li>P Sand : Plastering Works</li>
            <li>Concrete Grade : M20 (Manual Mix)</li>
            <li>Ceiling Height : 10 Feet</li>
            <li>Steel Reinforcement : As per Standard</li>
            <li>Parapet Wall : 3 Feet Height | 4" Thick (Only for Floor with Headroom)</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Bathroom & Plumbing <span>+</span></button>
        <div class="content">
          <ul>
            <li>Wall Tiles : Up to 7' height, 2'x1' vitrified tile, up to ₹40/sqft</li>
            <li>Bath & CP Fittings : Cera | up to ₹12,000 per bathroom</li>
            <li>Plumbing Pipes & Fittings : Inner CPVC, Outer PVC (Any ISI Brand)</li>
            <li>Overhead Tank : 1000L Sintex, 3-layer, UV protected</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Flooring <span>+</span></button>
        <div class="content">
          <ul>
            <li>Living/Dining/Bedrooms/Kitchen: 2'x2' vitrified tiles up to ₹45/sqft</li>
            <li>Balcony & Utility: 1'x1' tiles up to ₹35/sqft</li>
            <li>Staircase: 1'x1' tile up to ₹35/sqft</li>
            <li>Car Parking: 1'x1' parking tile up to ₹35/sqft</li>
            <li>Terrace: Screed concreting with waterproofing</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Kitchen & Dining <span>+</span></button>
        <div class="content">
          <ul>
            <li>Wall Tile: Vitrified 2'x1' up to ₹45/sqft</li>
            <li>Sink Faucet: up to ₹900</li>
            <li>Kitchen Sink: Stainless steel single bowl up to ₹2,800</li>
            <li>Kitchen Granite Top: up to ₹90/sqft</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Door, Windows and Railing <span>+</span></button>
        <div class="content">
          <ul>
            <li>Main Door: Malaysian Teak door & frame (32mm)</li>
            <li>Room Doors: White panel door with Sal wood frame</li>
            <li>Bathroom Door: PVC door</li>
            <li>Windows: Aluminium sliding, max 4'×4', 5mm clear glass</li>
            <li>Staircase/Balcony Railing: MS Railing</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Painting <span>+</span></button>
        <div class="content">
          <ul>
            <li>Inner Wall Putty: 2 coats (Any ISI Brand)</li>
            <li>Wall Painting: 1 coat primer + 2 coats Tractor emulsion</li>
            <li>Ceiling Painting: 1 coat primer + 2 coats Tractor emulsion</li>
            <li>Exterior Paint: 1 coat primer + 2 coats Ace</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">Electrical <span>+</span></button>
        <div class="content">
          <ul>
            <li>Wires: Essar</li>
            <li>Switches: Fybros</li>
            <li>Bedroom: 2 switch boxes (8-module)</li>
            <li>Bathroom: 1 inner (4-module) + 1 outer (3-module)</li>
            <li>Living Room: up to 4 switch boxes (8-module)</li>
            <li>Kitchen: 3 switch boxes (6-module) with points for HOB, Chimney, RO</li>
            <li>AC Points: 1 per bedroom</li>
          </ul>
        </div>
      </div>

      <div class="accordion-item">
        <button class="accordion-btn">What's Not Included <span>-</span></button>
        <div class="content open">
          <ul>
            <li>Compound Wall @ ₹425/sqft & Gate</li>
            <li>Sump & Septic Tank @ ₹24/litre</li>
            <li>Lift, Lift Pit and Shaft</li>
            <li>Electricity Connection</li>
            <li>Building Plan Approval</li>
            <li>Elevation Special Materials</li>
            <li>Elevation light points and Surface Light Points: ₹600 per point</li>
          </ul>
