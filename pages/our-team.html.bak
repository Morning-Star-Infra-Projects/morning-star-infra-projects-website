<!-- ═══ HERO ══════════════════════════════════════════════ -->
  <section class="hero-split" aria-label="Our Team Hero">
    <div class="hero-split-left">
      <div class="hero-split-left-inner" style="text-align:center">
        <div class="hero-tag">Our Team</div>
        <h1 class="hero-title">The Experts Behind Chennai's Trusted Construction Company</h1>
        <p class="hero-sub">Civil engineers, architects, project managers, and construction professionals — united by a single commitment: delivering excellence on every project.</p>
        <div class="hero-btns" style="text-align:center">
          <button class="btn-primary" onclick="document.getElementById('team-expertise').scrollIntoView({behavior:'smooth'})">Meet Our Experts</button>
          <button class="btn-secondary" onclick="openModal()">Contact Us</button>
        </div>
      </div>
    </div>
    <!-- hero image removed as requested -->
