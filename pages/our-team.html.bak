  <!-- Team stats section removed -->

  <!-- ═══ TEAM INTRO ══════════════════════════════════════════ -->
  <section class="section" id="team-expertise" aria-labelledby="team-intro-title">
    <div class="container" style="text-align:center;max-width:820px">
      <span class="section-tag">Meet Our Experts</span>
      <h2 class="section-title" id="team-intro-title" style="margin:0 auto 16px">Engineering Excellence Powered by People</h2>
      <p class="section-sub" style="margin:0 auto 0;max-width:660px">Our experienced team of civil engineers, architects, project managers, interior specialists, and construction professionals delivers premium construction solutions across Chennai. Every project is led by qualified engineers committed to structural integrity, design precision, and transparent execution.</p>
    </div>
  </section>

  <!-- ═══ EXPERTISE CARDS ═══════════════════════════════════ -->
  <section class="section-sm sec-cream" aria-labelledby="expertise-grid-title">
    <div class="container">
      <div style="text-align:center;margin-bottom:48px">
        <span class="section-tag">Disciplines</span>
        <h2 class="section-title" id="expertise-grid-title" style="margin:0 auto 12px">Meet the Specialists</h2>
        <p class="section-sub" style="margin:0 auto;max-width:580px">Every role in our team is filled by a trained professional who brings precision and accountability to every stage of construction.</p>
      </div>
      <div class="expertise-grid reveal">
        <div class="expertise-card">
          <div class="expertise-card-icon"><i data-lucide="hard-hat"></i></div>
          <h3 class="expertise-card-title">Civil Engineers</h3>
          <p class="expertise-card-text">Residential and commercial construction specialists certified by governing bodies. They oversee structural design, load calculations, and site execution to ensure every build meets IS standards.</p>
        </div>
        <div class="expertise-card">
          <div class="expertise-card-icon"><i data-lucide="clipboard-list"></i></div>
          <h3 class="expertise-card-title">Project Managers</h3>
          <p class="expertise-card-text">Efficient planning and execution professionals who coordinate timelines, budgets, labour, and materials — keeping every project on schedule and within budget without compromise.</p>
        </div>
        <div class="expertise-card">
          <div class="expertise-card-icon"><i data-lucide="pencil-ruler"></i></div>
          <h3 class="expertise-card-title">Architects</h3>
          <p class="expertise-card-text">Modern and innovative design solutions combining functionality with aesthetics. They transform client briefs into detailed 2D drawings and realistic 3D renders before a single brick is laid.</p>
        </div>
        <div class="expertise-card">
          <div class="expertise-card-icon"><i data-lucide="sofa"></i></div>
          <h3 class="expertise-card-title">Interior Designers</h3>
          <p class="expertise-card-text">Elegant and functional spaces crafted with bespoke furniture, curated materials, and in-house manufacturing. From living rooms to modular kitchens — every inch is designed intentionally.</p>
        </div>
        <div class="expertise-card">
          <div class="expertise-card-icon"><i data-lucide="activity"></i></div>
          <h3 class="expertise-card-title">Structural Experts</h3>
          <p class="expertise-card-text">Repair and retrofitting specialists trained in NDT diagnostics, FRP jacketing, and advanced grouting techniques to extend building life and restore structural integrity safely.</p>
        </div>
        <div class="expertise-card">
          <div class="expertise-card-icon"><i data-lucide="eye"></i></div>
          <h3 class="expertise-card-title">Site Supervisors</h3>
          <p class="expertise-card-text">Quality control and project monitoring professionals who are present on site daily — ensuring workmanship standards, material quality, and safety protocols are never compromised.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ OUR EXPERTISE BADGES ══════════════════════════════ -->
  <section class="section" aria-labelledby="expertise-badges-title">
    <div class="container">
      <div style="text-align:center;margin-bottom:48px">
        <span class="section-tag">What We Deliver</span>
        <h2 class="section-title" id="expertise-badges-title" style="margin:0 auto 12px">Our Areas of Expertise</h2>
        <p class="section-sub" style="margin:0 auto;max-width:560px">Every service is backed by a dedicated team of specialists with domain experience and technical qualifications.</p>
      </div>
      <div class="team-badges-grid reveal">
        <div class="team-badge">
